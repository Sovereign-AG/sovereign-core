{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovereign-ag.com/schemas/v1/agent-identity.json",
  "title": "Sovereign AI Agent Identity Schema",
  "description": "Standardized cryptographic identity and capability registration for autonomous agents.",
  "type": "object",
  "required": [
    "did",
    "owner",
    "signature",
    "capabilities"
  ],
  "properties": {
    "did": {
      "type": "string",
      "description": "Decentralized Identifier (DID) starting with did:sov:",
      "pattern": "^did:sov:[a-zA-Z0-9]+$"
    },
    "owner": {
      "type": "string",
      "description": "Cryptographic public key of the agent controller (Ed25519 or NIST-P256)"
    },
    "signature": {
      "type": "string",
      "description": "Ed25519 signature verifying the agent's integrity hash"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Restricted scope of autonomous actions (e.g., 'read:fs', 'exec:finance')"
    },
    "trustScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 100
    },
    "nist_compliance": {
      "type": "string",
      "enum": ["SP-800-218", "Non-Compliant"],
      "default": "SP-800-218"
    }
  }
}
