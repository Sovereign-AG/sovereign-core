{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SovereignAgentSchema",
  "description": "Information definition for an AI Agent within the Sovereign Registry",
  "type": "object",
  "properties": {
    "did": {
      "type": "string",
      "description": "Decentralized Identifier (e.g. did:sov:12345)"
    },
    "alias": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "description": "Organization or Individual responsible for the agent"
    },
    "purpose": {
      "type": "string"
    },
    "nist_status": {
      "type": "string",
      "enum": ["Verified", "Warning", "Non-Compliant"]
    },
    "heartbeat_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "status": {
      "type": "string",
      "enum": ["Active", "Quarantined", "TERMINATED"]
    }
  },
  "required": ["did", "alias", "owner", "nist_status", "status"]
}
